@model CoreFitnessClub.Presentation.Mvc.ViewModels.Auth.SetPasswordViewModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Set Password";
    ViewData["HeaderVariant"] = "Default";

    var formAction = ViewData["FormAction"] as string ?? "SetPassword";
}

<section>
    <div class="mx-auto w-full max-w-215 rounded-2xl bg-white px-16 py-10">
        <div>
            <h2 class="text-[56px]">Set Your Password</h2>
            <p class="pb-10">Create your password to finish setting up your account.</p>
        </div>

        <div class="mb-16 h-px flex-1 bg-gray-light"></div>

        <form asp-controller="Auth" asp-action="@formAction" method="post" data-form-validation>
            <input asp-for="Email" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="pb-6" style="color: red;"></div>

            <div>
                <label asp-for="Password" class="block pb-4 pt-8 font-poppins text-sm font-semibold text-primary">Password *</label>
                <input asp-for="Password" placeholder="Enter Password" class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none focus:border-accent" />
                <span asp-validation-for="Password" style="color: red;"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block pb-4 pt-8 font-poppins text-sm font-semibold text-primary">Confirm Password *</label>
                <input asp-for="ConfirmPassword" placeholder="Confirm Password" class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none focus:border-accent" />
                <span asp-validation-for="ConfirmPassword" style="color: red;"></span>
            </div>

            <div class="w-full py-12">
                <button type="submit"
                        class="relative mx-auto flex w-full max-w-139 cursor-pointer items-center justify-center rounded-full bg-accent px-6 py-4 font-dm-sans text-base font-semibold text-primary">
                    <span>Continue</span>
                    <span class="absolute right-4 top-1/2 -translate-y-1/2">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="h-5 w-5"
                             viewBox="0 0 20 20"
                             fill="currentColor">
                            <path fill-rule="evenodd"
                                  d="M7.22 4.22a.75.75 0 011.06 0l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06L11.94 10 7.22 5.28a.75.75 0 010-1.06z"
                                  clip-rule="evenodd" />
                        </svg>
                    </span>
                </button>
            </div>
        </form>
    </div>
</section>