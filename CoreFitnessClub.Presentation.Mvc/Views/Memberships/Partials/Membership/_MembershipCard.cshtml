@model CoreFitnessClub.Presentation.Mvc.ViewModels.Memberships.MembershipCardViewModel
@{
    var isAdmin = User.IsInRole("Admin");
    var isMember = User.IsInRole("Member");
    var membershipsReturnUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl)
        ? Url.Action("Index", "Memberships")
        : Url.Action("Index", "Memberships", new { returnUrl = Model.ReturnUrl });
}
<div class="rounded-[20px] bg-white px-0 py-0">
    <div class="flex h-full flex-col gap-6 rounded-[20px] bg-white pt-10 pb-4">

        <div class="flex flex-1 flex-col gap-6 px-10">

            <div class="mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-accent">
                <svg width="30" height="18" viewBox="0 0 30 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21.75 0C23.1562 0 24.3281 0.9375 24.6562 2.25H25.125C27 2.25 28.5 3.75 28.5 5.625V7.875H28.875C29.4844 7.875 30 8.39062 30 9C30 9.60938 29.4844 10.125 28.875 10.125H28.5V12.375C28.5 14.25 27 15.75 25.125 15.75H24.6562C24.3281 17.0625 23.1562 18 21.75 18C20.1094 18 18.75 16.6406 18.75 15V10.125H11.25V15C11.25 16.6406 9.89062 18 8.25 18C6.84375 18 5.67188 17.0625 5.34375 15.75H4.875C3 15.75 1.5 14.25 1.5 12.375V10.125H1.125C0.515625 10.125 0 9.60938 0 9C0 8.39062 0.515625 7.875 1.125 7.875H1.5V5.625C1.5 3.75 3 2.25 4.875 2.25H5.34375C5.67188 0.9375 6.84375 0 8.25 0C9.89062 0 11.25 1.35938 11.25 3V7.875H18.75V3C18.75 1.35938 20.1094 0 21.75 0ZM8.25 2.25C7.82812 2.25 7.5 2.57812 7.5 3V15C7.5 15.4219 7.82812 15.75 8.25 15.75C8.67188 15.75 9 15.4219 9 15V3C9 2.57812 8.67188 2.25 8.25 2.25ZM21.75 2.25C21.3281 2.25 21 2.57812 21 3V15C21 15.4219 21.3281 15.75 21.75 15.75C22.1719 15.75 22.5 15.4219 22.5 15V3C22.5 2.57812 22.1719 2.25 21.75 2.25ZM4.875 4.5C4.26562 4.5 3.75 5.01562 3.75 5.625V12.375C3.75 12.9844 4.26562 13.5 4.875 13.5H5.25V4.5H4.875ZM24.75 13.5H25.125C25.7344 13.5 26.25 12.9844 26.25 12.375V5.625C26.25 5.01562 25.7344 4.5 25.125 4.5H24.75V13.5Z"
                          fill="black" />
                </svg>
            </div>

            <h3>@Model.Name</h3>

            <hr class="border-t border-gray-light" />

            <p>
                With the @Model.Name, get access to our full range of gym facilities.
            </p>

            <ul class="flex flex-col gap-4 py-2 font-dm-sans text-base text-gray">
                @foreach (var feature in Model.Features)
                {
                    <li class="flex items-center gap-2">
                        <div class="flex h-4 w-4 items-center justify-center rounded-full bg-accent">
                            <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
                                <path d="M7.69922 0.175781C7.94531 0.369141 7.99805 0.720703 7.82227 0.966797L3.32227 7.1543C3.2168 7.27734 3.07617 7.36523 2.91797 7.38281C2.74219 7.40039 2.58398 7.33008 2.46094 7.22461L0.210938 4.97461C0 4.74609 0 4.39453 0.210938 4.16602C0.439453 3.95508 0.791016 3.95508 1.01953 4.16602L2.79492 5.95898L6.9082 0.298828C7.10156 0.0527344 7.45312 0 7.69922 0.175781Z"
                                      fill="white" />
                            </svg>
                        </div>
                        @feature
                    </li>
                }
            </ul>
        </div>

        <div class="mx-4 flex flex-col gap-6 rounded-[20px] bg-secondary px-4 py-8">

            <div class="flex items-center justify-between">

                <div class="flex flex-col gap-1">
                    <p class="font-poppins text-[1.5rem] font-bold text-white">
                        @Model.PricePerMonth.ToString("0.00")
                        <span class="font-dm-sans text-[.75rem] font-medium">/monthly</span>
                    </p>
                    <p class="text-white">
                        Monthly @Model.ClassesPerMonth Classes
                    </p>
                </div>

                @if (isAdmin)
                {
                    <div class="inline-flex cursor-not-allowed items-center gap-2 rounded-full bg-gray-light px-7 py-4 font-dm-sans font-semibold text-primary opacity-70">
                        Join Now
                        <svg width="8" height="15" viewBox="0 0 8 15" fill="none">
                            <path d="M7.62504 6.53125C7.90629 6.8125 7.90629 7.3125 7.62504 7.59375L1.37504 13.8438C1.06254 14.125 0.593791 14.125 0.312541 13.8438C4.1008e-05 13.5625 4.1008e-05 13.0625 0.312541 12.7812L6.03129 7.0625L0.312541 1.34375C4.1008e-05 1.0625 4.1008e-05 0.5625 0.312541 0.28125C0.593791 0 1.06254 0 1.37504 0.28125L7.62504 6.53125Z"
                                  fill="#27252F" />
                        </svg>
                    </div>
                }
                else if (isMember)
                {
                    <form asp-controller="Memberships" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MembershipPlanId" value="@Model.Id" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                        <button type="submit"
                                class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-accent px-7 py-4 font-dm-sans font-semibold text-primary">
                            Join Now
                            <svg width="8" height="15" viewBox="0 0 8 15" fill="none">
                                <path d="M7.62504 6.53125C7.90629 6.8125 7.90629 7.3125 7.62504 7.59375L1.37504 13.8438C1.06254 14.125 0.593791 14.125 0.312541 13.8438C4.1008e-05 13.5625 4.1008e-05 13.0625 0.312541 12.7812L6.03129 7.0625L0.312541 1.34375C4.1008e-05 1.0625 4.1008e-05 0.5625 0.312541 0.28125C0.593791 0 1.06254 0 1.37504 0.28125L7.62504 6.53125Z"
                                      fill="#27252F" />
                            </svg>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Auth"
                           asp-action="SignUp"
                           asp-route-returnUrl="@membershipsReturnUrl"
                           class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-accent px-7 py-4 font-dm-sans font-semibold text-primary">
                        Join Now
                        <svg width="8" height="15" viewBox="0 0 8 15" fill="none">
                            <path d="M7.62504 6.53125C7.90629 6.8125 7.90629 7.3125 7.62504 7.59375L1.37504 13.8438C1.06254 14.125 0.593791 14.125 0.312541 13.8438C4.1008e-05 13.5625 4.1008e-05 13.0625 0.312541 12.7812L6.03129 7.0625L0.312541 1.34375C4.1008e-05 1.0625 4.1008e-05 0.5625 0.312541 0.28125C0.593791 0 1.06254 0 1.37504 0.28125L7.62504 6.53125Z"
                                  fill="#27252F" />
                        </svg>
                    </a>
                }
            </div>

            <hr class="border-t border-primary" />

            <p class="text-white">
                Try Any Membership Free for @Model.TrialWeeks Week@(Model.TrialWeeks == 1 ? "" : "s")
            </p>
        </div>
    </div>
</div>