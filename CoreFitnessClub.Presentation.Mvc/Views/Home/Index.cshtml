@{
    ViewData["Title"] = "Home";
    ViewData["HideGlobalHeader"] = true;
    ViewData["HeaderVariant"] = "Home";
    ViewData["ActivePage"] = "Home";
}

<section class="px-4 py-4">
    <div class="mx-auto max-w-472">
        <div class="relative overflow-hidden rounded-t-2xl rounded-b-2xl bg-primary">
            <img src="~/images/dark-section-img.svg"
                 alt=""
                 aria-hidden="true"
                 class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-60" />

            <div class="relative z-10">
                <partial name="~/Views/Shared/Partials/Header/_Header.cshtml" />
                <partial name="~/Views/Shared/Partials/Hero/_HeroSection.cshtml" />
            </div>
        </div>

        <partial name="~/Views/Shared/Partials/Banner/_HomeBanner.cshtml" />
        <partial name="~/Views/Shared/Partials/About/_AboutSection.cshtml" />
        <partial name="~/Views/Shared/Partials/Programs/_ProgramsSection.cshtml" />
        <partial name="~/Views/Shared/Partials/Store/_StoreSection.cshtml" />
    </div>
</section>