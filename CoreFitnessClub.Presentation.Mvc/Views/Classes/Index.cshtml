@model CoreFitnessClub.Presentation.Mvc.ViewModels.Classes.ClassesIndexViewModel

@{
    ViewData["Title"] = "Our Classes";
    ViewData["HeaderVariant"] = "Default";
    ViewData["ActivePage"] = "Classes";
}

<section class="px-4 py-4">
    <div class="mx-auto max-w-472">
        <div class="rounded-2xl bg-white px-6 py-8 md:px-10">
            <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-3 text-center md:text-left">
                    <p class="font-dm-sans text-sm font-semibold uppercase tracking-[0.2em] text-accent">
                        Training Schedule
                    </p>
                    <h2>Our Classes</h2>
                    <p class="mx-auto max-w-180 md:mx-0">
                        Explore our upcoming classes and find the training session that fits your schedule.
                    </p>
                </div>

                @if (TempData["SuccessMessage"] is string successMessage)
                {
                    <div class="mt-4 rounded-2xl bg-background px-6 py-4">
                        <p>@successMessage</p>
                    </div>
                }

                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="mt-4 rounded-2xl bg-background px-6 py-4">
                        <p style="color: red;">@errorMessage</p>
                    </div>
                }

                <div class="mt-4 flex flex-col gap-4">
                    @if (Model.Classes.Count == 0)
                    {
                        <div class="rounded-2xl bg-background px-6 py-8 text-center">
                            <p>No classes available right now.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var trainingClass in Model.Classes)
                        {
                            var isBooked = Model.BookedTrainingClassIds.Contains(trainingClass.Id);
                            var isAdmin = User.IsInRole("Admin");

                            <article class="rounded-2xl bg-background px-6 py-6">
                                <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                                    <div class="flex flex-col gap-4">
                                        <div class="flex flex-wrap items-center gap-3">
                                            @if (!string.IsNullOrWhiteSpace(trainingClass.Category))
                                            {
                                                <span class="rounded-full bg-accent px-4 py-2 font-dm-sans text-sm font-semibold text-primary">
                                                    @trainingClass.Category
                                                </span>
                                            }

                                            <span class="font-dm-sans text-sm text-gray">
                                                @trainingClass.StartsAt.ToString("dddd, dd MMMM")
                                            </span>
                                        </div>

                                        <div class="flex flex-col gap-2">
                                            <h3>@trainingClass.Name</h3>

                                            <div class="flex flex-col gap-1 font-dm-sans text-base text-gray">
                                                <p>@trainingClass.StartsAt.ToString("HH:mm") - @trainingClass.EndsAt.ToString("HH:mm")</p>

                                                @if (!string.IsNullOrWhiteSpace(trainingClass.InstructorName))
                                                {
                                                    <p>Instructor: @trainingClass.InstructorName</p>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex justify-start lg:justify-end">
                                        @if (isAdmin)
                                        {
                                            <div class="inline-flex items-center rounded-full bg-gray-light px-6 py-4 font-dm-sans text-sm font-semibold text-primary opacity-70">
                                                Book class
                                            </div>
                                        }
                                        else if (isBooked)
                                        {
                                            <div class="inline-flex items-center rounded-full bg-secondary px-6 py-4 font-dm-sans text-sm font-semibold text-white">
                                                Booked
                                            </div>
                                        }
                                        else if (!Model.HasActiveMembership)
                                        {
                                            <a asp-controller="Memberships"
                                                   asp-action="Index"
                                                   class="inline-flex cursor-pointer items-center rounded-full bg-gray-light px-6 py-4 font-dm-sans text-sm font-semibold text-primary">
                                                Get membership
                                            </a>
                                        }
                                        else
                                        {
                                            <form asp-controller="Bookings" asp-action="Book" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="trainingClassId" value="@trainingClass.Id" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="inline-flex cursor-pointer items-center rounded-full bg-primary px-6 py-4 font-dm-sans text-sm font-semibold text-white">
                                                    Book class
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>