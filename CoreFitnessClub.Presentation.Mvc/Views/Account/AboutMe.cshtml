@model CoreFitnessClub.Presentation.Mvc.ViewModels.Account.AboutMeViewModel
@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "About Me";
    ViewData["HeaderVariant"] = "Default";
    ViewData["AccountTitle"] = "About Me";
}

<form asp-action="AboutMe" method="post" enctype="multipart/form-data" class="mt-6" data-form-validation>
    <div asp-validation-summary="ModelOnly" class="pb-4" style="color: red;"></div>

    <div class="grid gap-4 border-t border-gray-light pt-8">
        <label asp-for="FirstName" class="font-poppins text-sm font-semibold">First Name</label>
        <input asp-for="FirstName" placeholder="Enter First Name" class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none placeholder:font-dm-sans placeholder:text-[#A7A7A7] focus:border-accent" />
        <span asp-validation-for="FirstName" style="color: red;"></span>
    </div>

    <div class="grid gap-4 pt-8">
        <label asp-for="LastName" class="font-poppins text-sm font-semibold">Last Name</label>
        <input asp-for="LastName" placeholder="Enter Last Name" class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none placeholder:font-dm-sans placeholder:text-[#A7A7A7] focus:border-accent" />
        <span asp-validation-for="LastName" style="color: red;"></span>
    </div>

    <div class="grid gap-4 pt-8">
        <label asp-for="Email" class="font-poppins text-sm font-semibold">Email Address *</label>
        <input asp-for="Email" readonly class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none placeholder:font-dm-sans placeholder:text-[#A7A7A7] focus:border-accent" />
        <span asp-validation-for="Email" style="color: red;"></span>
    </div>

    <div class="grid gap-4 pb-12 pt-8">
        <label asp-for="PhoneNumber" class="font-poppins text-sm font-semibold">Phone Number</label>
        <input asp-for="PhoneNumber" placeholder="Enter Phone Number" class="w-full rounded-xl border border-transparent bg-background px-6 py-4 font-dm-sans text-base text-secondary outline-none placeholder:font-dm-sans placeholder:text-[#A7A7A7] focus:border-accent" />
        <span asp-validation-for="PhoneNumber" style="color: red;"></span>
    </div>

    <div class="grid gap-4 border-t border-gray-light pt-8">
        <label for="profileImage" class="font-poppins text-sm font-semibold">Profile Image</label>

        <label id="profileImageFileName"
            for="profileImage"
            class="w-full cursor-pointer rounded-xl bg-background px-6 py-4 font-dm-sans text-base text-[#A7A7A7]">
            Upload Profile Image
        </label>
    
        <input asp-for="ProfileImage"
               id="profileImage"
               type="file"
               accept="image/*"
               class="hidden"
               data-image-preview-target="accountProfileImage" />
    </div>

    <div class="flex justify-end pt-8">
        <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-dm-sans text-base font-semibold whitespace-nowrap text-primary">
            <span>Save</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd"
                      d="M7.22 4.22a.75.75 0 011.06 0l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06L11.94 10 7.22 5.28a.75.75 0 010-1.06z"
                      clip-rule="evenodd" />
            </svg>
        </button>
    </div>
</form>