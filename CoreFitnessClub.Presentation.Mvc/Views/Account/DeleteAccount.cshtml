@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "Delete Account";
    ViewData["HeaderVariant"] = "Default";
    ViewData["AccountTab"] = "";
    ViewData["AccountTitle"] = "Remove Account";

    var deleteAccountError = TempData["DeleteAccountError"] as string;
}

<section class="mt-6">
    <div class="border-t border-gray-light pt-8">
        <h3 class="font-poppins text-2xl font-semibold text-primary">Remove your account</h3>
        <p class="pt-4 font-dm-sans text-base text-secondary">
            This action will remove your account and your saved personal information.
        </p>

        @if (!string.IsNullOrWhiteSpace(deleteAccountError))
        {
            <p class="pt-6" style="color: red;">@deleteAccountError</p>
        }

        <form asp-action="DeleteAccountConfirmed" method="post" class="pt-10">
            <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-dm-sans text-base font-semibold text-primary">
                <span>Delete Account</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                          d="M7.22 4.22a.75.75 0 011.06 0l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06L11.94 10 7.22 5.28a.75.75 0 010-1.06z"
                          clip-rule="evenodd" />
                </svg>
            </button>
        </form>
    </div>
</section>