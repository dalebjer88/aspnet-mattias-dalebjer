@model List<CoreFitnessClub.Application.Features.Bookings.UserBookingDto>

@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "My Bookings";
    ViewData["HeaderVariant"] = "Default";
    ViewData["ActivePage"] = "Account";
    ViewData["AccountTab"] = "MyBookings";
    ViewData["AccountTitle"] = "My Bookings";
}

<div class="mt-6 border-t border-gray-light pt-8">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="mb-6 rounded-2xl bg-background px-6 py-4">
            <p>@successMessage</p>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="mb-6 rounded-2xl bg-background px-6 py-4">
            <p style="color: red;">@errorMessage</p>
        </div>
    }

    @if (Model.Count == 0)
    {
        <p class="font-dm-sans text-base text-secondary">You do not have any booked classes yet.</p>
    }
    else
    {
        <div class="flex flex-col gap-6">
            @foreach (var booking in Model)
            {
                <article class="rounded-[20px] bg-white px-6 py-6">
                    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                        <div class="flex flex-col gap-3">
                            <div class="flex flex-wrap items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(booking.Category))
                                {
                                    <span class="rounded-full bg-accent px-4 py-2 font-dm-sans text-sm font-semibold text-primary">
                                        @booking.Category
                                    </span>
                                }

                                <span class="font-dm-sans text-sm text-gray">
                                    @booking.StartsAt.ToString("dddd, dd MMMM")
                                </span>
                            </div>

                            <div class="flex flex-col gap-1">
                                <h3>@booking.Name</h3>
                                <p class="font-dm-sans text-base text-gray">
                                    @booking.StartsAt.ToString("HH:mm") - @booking.EndsAt.ToString("HH:mm")
                                </p>

                                @if (!string.IsNullOrWhiteSpace(booking.InstructorName))
                                {
                                    <p class="font-dm-sans text-base text-gray">Instructor: @booking.InstructorName</p>
                                }
                            </div>
                        </div>

                        <div class="flex justify-start lg:justify-end">
                            <form asp-controller="Bookings" asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="trainingClassId" value="@booking.TrainingClassId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="inline-flex cursor-pointer items-center rounded-full bg-primary px-6 py-4 font-dm-sans text-sm font-semibold text-white">
                                    Cancel booking
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>